{
  "manifest_version": 3,
  "name": "TikTok Auto Unfollow Pro",
  "version": "2.0",
  "description": "High-speed, stable TikTok unfollower with a native dark UI.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
