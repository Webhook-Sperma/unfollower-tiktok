{
  "manifest_version": 3,
  "name": "TikTok Auto Unfollow",
  "version": "1.0",
  "description": "Automatically unfollow users on TikTok one by one.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TikTok Auto Unfollow"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tiktok.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
